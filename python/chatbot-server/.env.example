# Required: OpenAI API key for LLM calls
OPENAI_API_KEY=sk-your-key-here

# Auth (hexagonal: postgres, supabase, or mock for tests)
# AUTH_PROVIDER=postgres
# JWT_SECRET_KEY=your-secret-for-signing-jwts  # required; min 32 bytes (RFC 7518)
# JWT_AUTH_TTL_SECONDS=900   # auth token TTL (default 15 min)
# JWT_REFRESH_TTL_SECONDS=86400  # refresh token TTL (default 24 h)
# SIGNUP_INVITE_KEY=         # optional; when set, signup requires this key in the request
# When AUTH_PROVIDER=postgres (runtime: use chatbot_app, not superuser):
# DATABASE_URL=postgresql://chatbot_app:chatbot@localhost:5432/chatbot
# Privileged URL for migrations only (docker POSTGRES_USER or superuser):
# MIGRATION_DATABASE_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot
# RUN_MIGRATIONS_ON_STARTUP=true
# When AUTH_PROVIDER=supabase:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_DATABASE_URL=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres  # optional; enables efficient get_user_by_email

# App data (chats, folders, etc.; hexagonal: postgres or mock)
# APP_DATA_PROVIDER=postgres   # default; uses same DB pool as auth when available
# APP_DATA_DATABASE_URL=postgresql://chatbot_app:chatbot@localhost:5432/chatbot

# Docker (run_test_server.sh / docker-compose)
# POSTGRES_DATA_PATH=./postgres_data  # host path for Postgres data; default: ./postgres_data

# Optional overrides (see src/settings.py for full list)
# DEBUG=false
# CORS_ORIGINS=*  # Alternative format: CORS_ORIGINS=https://app.example.com,https://admin.example.com
# MAX_CHAT_MESSAGES=50
# MAX_MESSAGE_CONTENT_LENGTH=16384
# ENABLE_DOCS=false
# PROMPT_API_URL=
# PROMPT_REFRESH_INTERVAL_SECONDS=300
