# Required: OpenAI API key for LLM calls
OPENAI_API_KEY=sk-your-key-here

# --- JWT (required outside tests) ---
# JWT_SECRET_KEY=your-secret-for-signing-jwts  # min 32 bytes (RFC 7518)
# JWT_AUTH_TTL_SECONDS=900
# JWT_REFRESH_TTL_SECONDS=86400
# SIGNUP_INVITE_KEY=

# --- Authentication (AUTHENTICATION_SERVICE_PROVIDER=sql | supabase | mock) ---
# sql: AUTHENTICATION_SERVICE_USERNAME, AUTHENTICATION_SERVICE_PASSWORD, and APP_DATA_DATABASE_* below. NO URLs need to be specified!
# supabase: AUTHENTICATION_SERVICE_URL, AUTHENTICATION_SERVICE_PASSWORD (service role); optional AUTHENTICATION_SERVICE_DATABASE_URL.
# AUTHENTICATION_SERVICE_URL=
# AUTHENTICATION_SERVICE_USERNAME=chatbot_app
# AUTHENTICATION_SERVICE_PASSWORD=
# AUTHENTICATION_SERVICE_DATABASE_URL=

# --- Application data database (APP_DATA_DATABASE_PROVIDER=sql | mock) ---
# APP_DATA_DATABASE_HOST=localhost
# APP_DATA_DATABASE_PORT=5432
# APP_DATA_DATABASE_NAME=chatbot
# APP_DATA_DATABASE_USERNAME=chatbot_app
# APP_DATA_DATABASE_PASSWORD=
# APP_DATA_DATABASE_ADMIN_USERNAME=chatbot
# APP_DATA_DATABASE_ADMIN_PASSWORD=
# APP_DATA_DATABASE_RUN_MIGRATIONS_ON_STARTUP=true
# After migrations, Postgres role passwords are set from the *_PASSWORD vars above (nothing hardcoded in SQL).

# --- Providers (shown above in each section; summary for quick reference) ---
# AUTHENTICATION_SERVICE_PROVIDER=sql   # sql | supabase | mock
# APP_DATA_DATABASE_PROVIDER=sql        # sql | mock

# Docker (run_test_server.sh / python/chatbot-server/docker-compose.yml)
# run_test_server.sh sources .env then .env.local (like Settings); passwords must be set in one of them.
# DATABASE_DATA_PATH=./database_data

# Optional overrides (see src/settings.py)
# DEBUG=false
# CORS_ORIGINS=*
# MAX_CHAT_MESSAGES=50
# MAX_MESSAGE_CONTENT_LENGTH=16384
# ENABLE_DOCS=false
# PROMPT_API_URL=
# PROMPT_REFRESH_INTERVAL_SECONDS=300
