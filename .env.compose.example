# Copy to .env in the repo root (docker compose loads it automatically):
#   cp .env.compose.example .env
#
# Naming mirrors python/chatbot-server/src/settings.py:
#   AUTHENTICATION_SERVICE_*  — auth port
#   APP_DATA_DATABASE_*       — application data database (cluster, runtime user, admin for migrations)

OPENAI_API_KEY=
JWT_SECRET_KEY=

# --- Application data database (cluster + roles) ---
# APP_DATA_DATABASE_NAME is passed to the Postgres image as POSTGRES_DB.
APP_DATA_DATABASE_ADMIN_USERNAME=chatbot
APP_DATA_DATABASE_ADMIN_PASSWORD=
APP_DATA_DATABASE_NAME=chatbot
APP_DATA_DATABASE_USERNAME=chatbot_app
APP_DATA_DATABASE_PASSWORD=

# --- Authentication service (SQL: same cluster as app data) ---
AUTHENTICATION_SERVICE_USERNAME=chatbot_app
AUTHENTICATION_SERVICE_PASSWORD=

# Optional: published ports on the host
# WEB_PORT=8080
# API_PORT=8000

# Optional: CORS for the API when calling it directly (e.g. port 8000). Same-origin via nginx usually needs * or your origin.
# CORS_ORIGINS=*
