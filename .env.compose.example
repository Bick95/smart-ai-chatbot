# Copy the contents of this file to .env in the repo root (docker compose loads it automatically):
#   cp .env.compose.example .env
#
# Names match python/chatbot-server/src/settings.py (that module loads and validates them).
#
# Why two prefixes? The app treats them as two separate "sides" in code:
#   APP_DATA_DATABASE_*      — Postgres + users for your app’s data (migrations vs normal queries).
#   AUTHENTICATION_SERVICE_* — Sign-in / identity. In this Compose stack it is SQL against Postgres,
#                             often the same database server as app data; the split is conceptual,
#                             not "two different machines" unless you configure it that way.

OPENAI_API_KEY=
JWT_SECRET_KEY=

# --- Application data: Postgres database + DB users for this stack ---
# POSTGRES_DB in the container is driven by APP_DATA_DATABASE_NAME below. Admin credentials are
# for migrations; APP_DATA_DATABASE_USERNAME/PASSWORD are what the API uses at runtime.
APP_DATA_DATABASE_ADMIN_USERNAME=chatbot
APP_DATA_DATABASE_ADMIN_PASSWORD=
APP_DATA_DATABASE_NAME=chatbot  # this value is passed to the Postgres image as POSTGRES_DB
APP_DATA_DATABASE_USERNAME=chatbot_app
APP_DATA_DATABASE_PASSWORD=

# --- Authentication (SQL): DB user the auth layer uses to talk to Postgres ---
# In Compose this is usually the same cluster as "application data" above; the example reuses
# chatbot_app so you do not need a second DB role until you choose to split auth from app data.
AUTHENTICATION_SERVICE_USERNAME=chatbot_app
AUTHENTICATION_SERVICE_PASSWORD=

# Optional
# WEB_PORT=8080  # The port under which the frontend is available on the host
# API_PORT=8000  # The port under which the backend-API is available on the host

# Optional: CORS_ORIGINS — browser security: which site origins may call the API. You care when
# the UI talks to http://localhost:8000 (or similar) directly. If everything goes through nginx
# on one URL, you may still need a value here for some setups; * is permissive, or list e.g.
# http://localhost:8080
# CORS_ORIGINS=*
